# VITE_GEMINI_API_KEY: Required if you deploy the frontend to a static host like Netlify!
# Since static hosting doesn't run the backend `server.ts`, the browser needs the API key
# to make direct calls to Gemini as a fallback.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Public Variables
VITE_FIREBASE_PROJECT_ID="gen-lang-client-xxxxxxxxxx"
VITE_FIREBASE_APP_ID="1:xxxx:web:xxxx"
VITE_FIREBASE_API_KEY="AIzaxxxxxxxxxxxxxx"
VITE_FIREBASE_AUTH_DOMAIN="gen-lang-client-xxxx.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-xxxx"
VITE_FIREBASE_STORAGE_BUCKET="gen-lang-client-xxxx.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="xxxx"
VITE_FIREBASE_MEASUREMENT_ID=""
