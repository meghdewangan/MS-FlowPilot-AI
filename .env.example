# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Public Variables
VITE_FIREBASE_PROJECT_ID="gen-lang-client-xxxxxxxxxx"
VITE_FIREBASE_APP_ID="1:xxxx:web:xxxx"
VITE_FIREBASE_API_KEY="AIzaxxxxxxxxxxxxxx"
VITE_FIREBASE_AUTH_DOMAIN="gen-lang-client-xxxx.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-xxxx"
VITE_FIREBASE_STORAGE_BUCKET="gen-lang-client-xxxx.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="xxxx"
VITE_FIREBASE_MEASUREMENT_ID=""
