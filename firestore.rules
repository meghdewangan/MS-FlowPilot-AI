rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 3: Global Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Phase 0: Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Phase 2: User Validation
    function isValidUser(data) {
      return data.keys().hasOnly(['email', 'displayName', 'photoURL', 'createdAt'])
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1024
        && data.createdAt == request.time;
    }
    
    // Phase 2: Meeting Validation
    function isValidMeeting(data) {
      return data.keys().hasAll(['title', 'ownerId', 'status'])
        && data.title is string && data.title.size() <= 200
        && data.ownerId == request.auth.uid
        && data.transcript is string && data.transcript.size() <= 100000
        && data.summary is string && data.summary.size() <= 20000
        && data.status is string && data.status.size() <= 50;
    }

    // Phase 2: Task Validation
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'ownerId', 'meetingId', 'status'])
        && data.title is string && data.title.size() <= 500
        && data.ownerId == request.auth.uid
        && data.meetingId is string && data.meetingId.size() <= 128
        && data.assignee is string && data.assignee.size() <= 100
        && data.deadline is string && data.deadline.size() <= 100
        && data.priority is string && data.priority.size() <= 50
        && data.status is string && data.status.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Users cannot list other users generally
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidUser(incoming());
      allow update: if isSignedIn() 
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      allow delete: if false;
    }

    match /meetings/{meetingId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && isValidId(meetingId)
        && isValidMeeting(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn()
        && existing().ownerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'summary', 'status'])
        && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && isValidId(taskId)
        && isValidTask(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn()
        && existing().ownerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'assignee', 'deadline', 'priority', 'status'])
        && incoming().ownerId == existing().ownerId
        && incoming().meetingId == existing().meetingId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
